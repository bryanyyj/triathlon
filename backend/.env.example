# Strava API credentials.
# Create an API app at https://www.strava.com/settings/api to get a Client ID/Secret.
# Once these are set, click "Connect Strava" in the app to authorize and store a refresh
# token automatically (or run `npm run strava:auth` for a one-off CLI flow).
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

PORT=3001
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000

# OpenRouter AI Coach (Phase 16) - leave blank to keep the coach disabled.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
